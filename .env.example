# Copie este arquivo para .env e preencha com seus dados.
# Nunca commite o arquivo .env (ele está no .gitignore).

# =============================================================================
# Database Configuration
# =============================================================================
# Format: postgresql://user:password@host:port/database
# IMPORTANT: Use a strong password in production!
DATABASE_URL=postgresql://postgres:your_secure_password@localhost:5432/erp_paraguay

# Database Connection Pool Settings
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# =============================================================================
# Application Settings
# =============================================================================
# Application environment: development, staging, or production
ENVIRONMENT=development

# Set to true for development debugging (shows detailed errors)
DEBUG=false

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# =============================================================================
# Security Settings (CRITICAL)
# =============================================================================
# Admin account configuration
# IMPORTANT: Always set ADMIN_PASSWORD in production!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_admin_password_here

# Password requirements
MIN_PASSWORD_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL=false

# Session management
SESSION_TIMEOUT_MINUTES=60
SESSION_REMEMBER_ME_DAYS=30

# Rate limiting settings
MAX_LOGIN_ATTEMPTS=5
LOGIN_BLOCK_MINUTES=15

# =============================================================================
# Company Information
# =============================================================================
# Company details for invoices and reports
COMPANY_NAME=My Company Name
COMPANY_ADDRESS=Your Business Address
COMPANY_PHONE=+595 21 123 456
COMPANY_EMAIL=contacto@yourcompany.com
COMPANY_WEBSITE=www.yourcompany.com
COMPANY_TAX_ID=12345678-9

# =============================================================================
# Tax Configuration
# =============================================================================
# Tax rate (as decimal, e.g., 0.10 for 10%)
TAX_RATE=0.10
# Tax name for display (IVA, VAT, Sales Tax, etc.)
TAX_NAME=IVA
# Tax display format
TAX_DISPLAY_FORMAT={name} ({rate}%)

# =============================================================================
# Invoice Settings
# =============================================================================
INVOICE_PREFIX=FAC
INVOICE_START_NUMBER=1
INVOICE_NUMBER_PADDING=6
INVOICE_PAYMENT_TERMS=30
INVOICE_DEFAULT_NOTES=Gracias por su compra. Para cualquier consulta, contáctenos.

# Currency formatting
CURRENCY_SYMBOL=ₓ
CURRENCY_CODE=PYG
CURRENCY_DECIMALS=2
THOUSANDS_SEPARATOR=,

# =============================================================================
# Inventory Settings
# =============================================================================
DEFAULT_REORDER_POINT=10
LOW_STOCK_THRESHOLD=10
ALLOW_NEGATIVE_STOCK=false
TRACK_STOCK_MOVEMENTS=true

# =============================================================================
# Report Settings
# =============================================================================
REPORT_DEFAULT_DATE_RANGE=30
REPORT_MAX_ROWS=1000
REPORT_DEFAULT_FORMAT=pdf
# Optional: Path to company logo for reports
# REPORT_LOGO_PATH=/path/to/logo.png

# =============================================================================
# UI Settings
# =============================================================================
# Date and time formatting
UI_DATE_FORMAT=%d/%m/%Y
UI_DATETIME_FORMAT=%d/%m/%Y %H:%M

# Number formatting
UI_DECIMAL_SEPARATOR=,
UI_THOUSANDS_SEPARATOR=.

# Table pagination
UI_DEFAULT_PAGE_SIZE=50
UI_MAX_PAGE_SIZE=500

# Theme colors (hex)
UI_PRIMARY_COLOR=#1a5276
UI_SECONDARY_COLOR=#5499c7
UI_SUCCESS_COLOR=#27ae60
UI_WARNING_COLOR=#f39c12
UI_DANGER_COLOR=#e74c3c

# =============================================================================
# Logging Settings
# =============================================================================
# Directory for application logs (will be created if it doesn't exist)
LOG_DIR=logs

# Maximum log file size before rotation (in bytes, default: 10MB)
LOG_MAX_BYTES=10485760

# Number of backup log files to keep
LOG_BACKUP_COUNT=5
